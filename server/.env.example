DATABASE_URL=postgres://postgres:YOUR_PASSWORD@YOUR_HOST:5432/phowson_gpt
HOST=0.0.0.0
PORT=2615
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
SESSION_TTL_DAYS=30

# 可选：对象存储（S3/R2/MinIO）
# 配置以下变量后，上传图片会写入对象存储，DB 仅保存 image_url（不再写入 image_bytes）
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# 可选：上传大小限制（字节）
UPLOAD_MAX_BYTES=62914560

# 可选：AI（填单/点评）
# 说明：前端不会直接调用大模型。仅后端读取环境变量。
# 选择一个提供方：gemini | openai | anthropic | openrouter | vercelai_gateway
AI_PROVIDER=
# 默认模型（不同提供方写不同模型名）
AI_MODEL=

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=

# OpenAI（OpenAI API / 兼容接口）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# OpenRouter（OpenAI 兼容）
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1
OPEN_ROUTER_MODEL=

# Vercel AI Gateway（OpenAI 兼容）
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
AI_GATEWAY_MODEL=

# 通用：任意 OpenAI 兼容接口（更灵活）
# 设置 AI_PROVIDER=openai_compatible 或不设置（自动按以下变量推断）
AI_API_KEY=
AI_BASE_URL=
AI_COMPATIBLE_API_KEY=
AI_COMPATIBLE_BASE_URL=
AI_COMPATIBLE_MODEL=

# 可选：本地启动脚本（restart.sh）使用的地址配置
# 这些变量不会影响后端服务本身，只用于脚本的健康检查与地址输出
PHOWSON_BACKEND_HOST=127.0.0.1  # 脚本健康检查访问的后端 host（默认 127.0.0.1 ）
PHOWSON_BACKEND_PORT=2615  # 后端端口（默认 2615 ）
PHOWSON_FRONTEND_PORT=2614  # 前端端口（默认 2614 ）
PHOWSON_VITE_HOST=0.0.0.0  # Vite dev server 监听地址（默认 0.0.0.0 ，方便局域网访问）
PHOWSON_FRONTEND_ACCESS_HOST=127.0.0.1  # 脚本用来检测“前端是否就绪”的访问 host（默认 127.0.0.1 ）
