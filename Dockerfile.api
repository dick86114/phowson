FROM node:22-alpine

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY server ./server
COPY constants.ts ./constants.ts

ENV HOST=0.0.0.0
ENV PORT=2615

EXPOSE 2615

CMD ["sh", "-lc", "pnpm db:migrate && pnpm admin:sync && pnpm dev:server"]
